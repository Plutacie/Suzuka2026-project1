# 复制本文件为 .env.local 后填写。Drizzle CLI（db:push 等）会自动加载 .env 与 .env.local。

# Neon（或任意兼容的 Postgres）连接串
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Vercel Blob：在 Vercel 项目 → Storage → Blob → 创建后获得 Read/Write Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# 可选：设置后所有创建/编辑 API 需在请求头 x-site-password 携带相同值；前端在页面「站点密码」输入框保存到会话
# SITE_PASSWORD="your-shared-secret"
